# Copy to `.env.local`. For zero-setup local OIDC, run `pnpm local:oidc` in another terminal,
# then `npx convex dev` (needs Node.js 18–24 for local Convex + `"use node"` actions) and `pnpm dev`.

# Convex (local dev URL comes from `npx convex dev`; cloud URLs work too)
VITE_CONVEX_URL=

# OIDC SPA client — must match Convex `OIDC_AUTHORITY` / `OIDC_CLIENT_ID` (`npx convex env set …`)
VITE_OIDC_AUTHORITY=
VITE_OIDC_CLIENT_ID=

# Optional LLM default on Convex (OpenAI-compatible chat fallback)
# OPENAI_API_KEY=
